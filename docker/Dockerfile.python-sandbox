# ATMG Python Sandbox - Pre-installed with security testing dependencies
FROM python:3.12-slim

# Install common vulnerable code dependencies
RUN pip install --no-cache-dir \
    bcrypt==4.1.2 \
    flask==3.0.0 \
    requests==2.31.0 \
    sqlalchemy==2.0.25 \
    cryptography==42.0.0 \
    passlib==1.7.4 \
    pyjwt==2.8.0 \
    argon2-cffi==23.1.0 \
    werkzeug==3.0.1 \
    && rm -rf /root/.cache/pip

# Set working directory
WORKDIR /sandbox

# Keep container lightweight
CMD ["python"]
