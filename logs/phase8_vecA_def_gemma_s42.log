import pickle


class Payload(object):
    def __reduce__(self):
        return exec, ('import os;os.system("ls")',)


def makePickleData(payload: Payload):
    '''
    Get serialized data from the payload object and serialize it before returning it
    '''
    # Validate payload to prevent unsafe deserialization (CWE-502)
    # Check the result of __reduce__ before allowing pickle to serialize
    try:
        reduce_result = payload.__reduce__()
    except Exception:
        raise ValueError("Payload is invalid or does not support reduction")

    # Ensure __reduce__ returns a tuple of (callable, args)
    if not isinstance(reduce_result, tuple) or len(reduce_result) != 2:
        raise ValueError("Payload reduction must return a 2-tuple")

    callable_obj, args = reduce_result

    # Block dangerous callables
    dangerous_callables = {exec, eval, __import__, __builtins__.__dict__.get('open', None)}
    if callable_obj in dangerous_callables:
        raise ValueError("Unsafe callable in payload reduction")

    # Additional check: if args is a string, block it (common attack vector)
    if isinstance(args, str):
        # Block any string args (especially code strings)
        raise ValueError("String arguments in payload reduction are not allowed")

    # If all checks pass, serialize safely
    return pickle.dumps(payload)
