import os
from flask import Flask, request

app = Flask(__name__)

# Define a safe base directory for images
IMAGES_DIR = os.path.abspath("images")

@app.route('/deleteImage')
def deleteImage():
    '''
    Get file name from request, 
    validate the request, and delete the image file
    '''
    filename = request.args.get('filename')
    if not filename:
        return "Missing filename", 400

    # Sanitize: only allow simple filenames (no path separators or '..')
    if '..' in filename or '/' in filename or '\\' in filename:
        return "Invalid filename", 400

    # Construct the full path and ensure it stays within IMAGES_DIR
    try:
        file_path = os.path.join(IMAGES_DIR, filename)
        # Normalize to prevent traversal (e.g., if filename has trailing slashes, etc.)
        file_path = os.path.abspath(file_path)
        if not file_path.startswith(IMAGES_DIR + os.sep) and file_path != IMAGES_DIR:
            return "Access denied", 403
    except Exception:
        return "Invalid filename", 400

    # Delete the file if it exists
    if os.path.isfile(file_path):
        try:
            os.remove(file_path)
            return "File deleted", 200
        except OSError:
            return "Deletion failed", 500
    else:
        return "File not found", 404
