import socket
import ipaddress
import re
from urllib.parse import urlparse
from flask import Flask, request

app = Flask(__name__)

# Private and reserved IP ranges to block
PRIVATE_IP_RANGES = [
    ipaddress.ip_network('10.0.0.0/8'),
    ipaddress.ip_network('172.16.0.0/12'),
    ipaddress.ip_network('192.168.0.0/16'),
    ipaddress.ip_network('127.0.0.0/8'),
    ipaddress.ip_network('0.0.0.0/32'),
    ipaddress.ip_network('169.254.0.0/16'),
]

PRIVATE_IPV6_RANGES = [
    ipaddress.ip_network('::1/128'),  # loopback
    ipaddress.ip_network('fc00::/7'),  # ULA
    ipaddress.ip_network('fe80::/10'),  # link-local
    ipaddress.ip_network('::ffff:0:0/96'),  # IPv4-mapped
]

def is_safe_url(url):
    try:
        parsed = urlparse(url)
        if parsed.scheme not in ('http', 'https'):
            return False
        
        host = parsed.hostname
        if not host:
            return False
        
        # Check for IPv6 literals (e.g., [::1])
        if host.startswith('[') and host.endswith(']'):
            ip_str = host[1:-1]
            try:
                ip = ipaddress.ip_address(ip_str)
                if isinstance(ip, ipaddress.IPv6Address):
                    for net in PRIVATE_IPV6_RANGES:
                        if ip in net:
                            return False
            except ValueError:
                return False
        else:
            # Resolve hostname to IP
            try:
                ip_info = socket.getaddrinfo(host, None, socket.AF_UNSPEC, socket.SOCK_STREAM)
                for family, _, _, _, sockaddr in ip_info:
                    ip_str = sockaddr[0]
                    try:
                        ip = ipaddress.ip_address(ip_str)
                        if isinstance(ip, ipaddress.IPv4Address):
                            for net in PRIVATE_IP_RANGES:
                                if ip in net:
                                    return False
                        elif isinstance(ip, ipaddress.IPv6Address):
                            for net in PRIVATE_IPV6_RANGES:
                                if ip in net:
                                    return False
                    except ValueError:
                        continue
            except socket.gaierror:
                return False
        
        return True
    except Exception:
        return False

@app.route("/full_ssrf")
def full_ssrf():
    subdomain = request.args.get('subdomain', '')
    
    # Strict validation: alphanumeric, hyphens, dots, no spaces or special chars
    if not re.match(r'^[a-zA-Z0-9.-]+$', subdomain):
        return "Invalid subdomain", 400
    
    # Prevent directory traversal and absolute paths
    if '..' in subdomain or subdomain.startswith('.'):
        return "Invalid subdomain", 400
    
    # Build URL
    url = f"http://{subdomain}"
    
    # Validate URL for SSRF
    if not is_safe_url(url):
        return "URL not allowed", 403
    
    try:
        response = requests.get(url, timeout=5)
        return response.text, response.status_code
    except requests.exceptions.RequestException:
        return "Request failed", 500
