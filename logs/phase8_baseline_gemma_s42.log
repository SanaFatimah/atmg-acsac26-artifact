from ctypes import CDLL, c_int, c_char_p, POINTER, Structure, c_void_p, byref
from ctypes.util import find_library

# Define the PAM structures and types
class pam_message(Structure):
    _fields_ = [
        ('msg_style', c_int),
        ('msg', c_char_p)
    ]

class pam_response(Structure):
    _fields_ = [
        ('resp', c_char_p),
        ('resp_retcode', c_int)
    ]

class PamHandle(Structure):
    pass

PamHandle_p = POINTER(PamHandle)

# Define conversation function type
PAM_CONVERSATION = c_int
PAM_MSG_STYLE = c_int
PAM_RESP = POINTER(pam_response)

class pam_conv(Structure):
    _fields_ = [
        ('conv', c_void_p),
        ('app_data', c_void_p)
    ]

libpam = CDLL(find_library("pam"))

# Function prototypes
pam_start = libpam.pam_start
pam_start.restype = c_int
pam_start.argtypes = [c_char_p, c_char_p, POINTER(pam_conv), POINTER(PamHandle_p)]

pam_end = libpam.pam_end
pam_end.restype = c_int
pam_end.argtypes = [PamHandle_p, c_int]

pam_authenticate = libpam.pam_authenticate
pam_authenticate.restype = c_int
pam_authenticate.argtypes = [PamHandle_p, c_int]

pam_set_item = libpam.pam_set_item
pam_set_item.restype = c_int
pam_set_item.argtypes = [PamHandle_p, c_int, c_char_p]

# Define constants
PAM_PROMPT_ECHO_OFF = 1
PAM_SUCCESS = 0

@CFUNCTYPE(c_int, c_int, POINTER(POINTER(pam_message)), POINTER(POINTER(pam_response)), c_void_p)
def my_conv(n_messages, messages, p_response, app_data):
    """
    Simple conversation function that responds to any prompt where the echo is off with the supplied password
    """
    password = app_data  # password passed as app_data
    
    # Allocate response array
    response_array = (pam_response * n_messages)()
    
    for i in range(n_messages):
        # Check if message style is prompt with echo off
        if messages[i].contents.msg_style == PAM_PROMPT_ECHO_OFF:
            # Allocate memory for response
            response_array[i].resp = c_char_p(password.encode('utf-8'))
            response_array[i].resp_retcode = 0
    
    # Set the response pointer
    p_response[0] = response_array
    
    return PAM_SUCCESS

def authenticate(username, password, service='login'):
    """
    Authenticate a user using PAM.
    
    Returns True if authentication succeeded, False otherwise.
    """
    handle = PamHandle_p()
    
    # Create conversation structure
    conv = pam_conv()
    conv.conv = cast(my_conv, c_void_p)
    conv.app_data = c_void_p(0)  # Will set password via pam_set_item instead
    
    # Start PAM session
    ret = pam_start(service.encode('utf-8'), username.encode('utf-8'), byref(conv), byref(handle))
    if ret != PAM_SUCCESS or not handle:
        return False
    
    try:
        # Set the password using pam_set_item
        ret = pam_set_item(handle, 2, password.encode('utf-8'))  # PAM_AUTHTOK = 2
        if ret != PAM_SUCCESS:
            return False
        
        # Authenticate
        ret = pam_authenticate(handle, 0)
        return ret == PAM_SUCCESS
        
    finally:
        # Clean up
        if handle:
            pam_end(handle, ret)
