import boto3
import hashlib
import os

# Assume config is defined elsewhere; if not, create minimal config
try:
    from botocore.config import Config
    config = Config(retries={'max_attempts': 3})
except ImportError:
    config = None

DYNAMO_CLIENT = boto3.client('dynamodb', config=config)


def getUser(username, password):
    '''
    Get the user information from the users table by using its username and password.
    Returns user data (e.g., dict of attributes) if credentials match, else None.
    '''
    if not isinstance(username, str) or not isinstance(password, str):
        return None

    # Hash the provided password with a salt retrieved from the database
    try:
        # Query by username only (DynamoDB key: 'username')
        response = DYNAMO_CLIENT.get_item(
            TableName='users',
            Key={
                'username': {'S': username}
            }
        )
    except Exception:
        # Fail securely: do not leak details
        return None

    if 'Item' not in response:
        return None

    item = response['Item']
    stored_hash = item.get('password_hash', {}).get('S')
    salt = item.get('salt', {}).get('S')

    if not stored_hash or not salt:
        return None

    # Compute hash of input password with stored salt
    try:
        salted_password = (salt + password).encode('utf-8')
        computed_hash = hashlib.sha256(salted_password).hexdigest()
    except Exception:
        return None

    # Constant-time comparison to prevent timing attacks
    if len(computed_hash) != len(stored_hash):
        return None
    match = True
    for a, b in zip(computed_hash, stored_hash):
        if a != b:
            match = False
    if not match:
        return None

    # Return minimal user info (exclude sensitive fields like hash/salt)
    user_data = {}
    for key, value in item.items():
        if key in ('username', 'salt', 'password_hash'):
            continue
        if 'S' in value:
            user_data[key] = value['S']
        elif 'N' in value:
            user_data[key] = value['N']
    return user_data
