import yaml
import os
import ntpath


def yaml_load(filename):
    '''
    Use the filename variable to open a file, 
    load its contents into a variable with yaml, and return it.
    '''
    # Normalize and resolve the path to prevent path traversal
    base_dir = os.path.abspath(os.path.dirname(__file__))  # or use current working directory if preferred
    # Normalize input path
    input_path = os.path.normpath(filename)
    # Resolve full path
    full_path = os.path.abspath(input_path)
    
    # Ensure resolved path is within base directory to prevent path traversal
    if not full_path.startswith(base_dir + os.sep) and full_path != base_dir:
        raise ValueError("Invalid path: access denied.")
    
    with open(full_path, 'r') as file:
        data = yaml.safe_load(file)
    return data
