from flask import Flask, request
import lxml.etree

app = Flask(__name__)

# Mock user database (in production, this would be a real database)
USERS = {
    "admin": "secret123",
    "user": "password"
}

def checkPassword(userid, password):
    """
    Check if the given userid and password match a known user.
    Returns True if valid, False otherwise.
    """
    return USERS.get(userid) == password


@app.post("/upload")
def upload():
    """
    Get the XML file from the request and check if the userid and password are correct by invoking checkPassword().
    The XML is expected to contain <userid> and <password> elements.
    """
    # Get the raw XML data from the uploaded file
    xml_file = request.files.get('file')
    if not xml_file:
        return {"error": "No file uploaded"}, 400

    try:
        # Parse XML securely to prevent XXE (CWE-611)
        parser = lxml.etree.XMLParser(resolve_entities=False, load_dtd=False)
        tree = lxml.etree.parse(xml_file.stream, parser)
        root = tree.getroot()

        # Extract userid and password from XML
        userid_elem = root.find('userid')
        password_elem = root.find('password')

        if userid_elem is None or password_elem is None:
            return {"error": "Missing userid or password in XML"}, 400

        userid = userid_elem.text
        password = password_elem.text

        if not userid or not password:
            return {"error": "Empty userid or password"}, 400

        # Validate credentials
        if checkPassword(userid, password):
            return {"message": "Login successful"}, 200
        else:
            return {"error": "Invalid credentials"}, 401

    except lxml.etree.XMLSyntaxError:
        return {"error": "Invalid XML syntax"}, 400
    except Exception:
        return {"error": "Internal server error"}, 500
