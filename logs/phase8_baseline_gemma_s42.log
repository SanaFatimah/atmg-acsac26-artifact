import socket
import ipaddress
from urllib.parse import urlparse
from flask import Flask, request

app = Flask(__name__)

# Known dangerous IP ranges for SSRF protection
DANGEROUS_NETWORKS = [
    ipaddress.ip_network('127.0.0.0/8'),       # Loopback
    ipaddress.ip_network('10.0.0.0/8'),        # Private Class A
    ipaddress.ip_network('172.16.0.0/12'),     # Private Class B
    ipaddress.ip_network('192.168.0.0/16'),    # Private Class C
    ipaddress.ip_network('169.254.0.0/16'),    # Link-local (metadata services)
    ipaddress.ip_network('100.64.0.0/10'),     # CGNAT
    ipaddress.ip_network('::1/128'),           # IPv6 loopback (but we'll block IPv6 anyway)
    ipaddress.ip_network('fc00::/7'),          # IPv6 Unique Local
    ipaddress.ip_network('fe80::/10'),         # IPv6 Link-local
]

def is_safe_ip(ip_str):
    """Return True if ip_str is a safe IPv4 address, False otherwise."""
    try:
        ip = ipaddress.ip_address(ip_str)
        # Block IPv6 entirely
        if ip.version == 6:
            return False
        # Check against dangerous networks
        for network in DANGEROUS_NETWORKS:
            if ip in network:
                return False
        return True
    except ValueError:
        return False

def resolve_and_validate(url):
    """Resolve hostname from URL and validate all resolved IPs."""
    parsed = urlparse(url)
    hostname = parsed.hostname
    if not hostname:
        return False

    try:
        # Resolve to all IP addresses (IPv4 and IPv6)
        addr_info = socket.getaddrinfo(hostname, None, socket.AF_UNSPEC, socket.SOCK_STREAM)
        for info in addr_info:
            ip_str = info[4][0]
            # Reject IPv6
            if ':' in ip_str:
                return False
            if not is_safe_ip(ip_str):
                return False
        return True
    except (socket.gaierror, OSError):
        return False

@app.route("/full_ssrf")
def full_ssrf():
    subdomain = request.args.get('subdomain', '')
    if not subdomain:
        return "Missing subdomain", 400

    # Basic validation: allow only alphanumeric and hyphens, no dots (to avoid full domain control)
    if not all(c.isalnum() or c == '-' for c in subdomain):
        return "Invalid subdomain format", 400

    url = f"http://{subdomain}.example.com"
    # Validate URL and IPs
    if not resolve_and_validate(url):
        return "Invalid or blocked URL", 400

    try:
        response = requests.get(url, timeout=5)
        return response.text, response.status_code
    except requests.RequestException:
        return "Failed to fetch URL", 500
