import ctypes
from ctypes import c_int, c_char_p, c_void_p, POINTER, Structure, c_char, c_uint, pointer
from ctypes.util import find_library

# Define PAM message and response structures
class PamMessage(Structure):
    _fields_ = [
        ('msg_style', c_int),
        ('msg', c_char_p),
    ]

class PamResponse(Structure):
    _fields_ = [
        ('resp', c_char_p),
        ('resp_retcode', c_int),
    ]

# Constants from pam_appl.h
PAM_PROMPT_ECHO_OFF = 1
PAM_PROMPT_ECHO_ON  = 2
PAM_ERROR_MSG       = 3
PAM_TEXT_INFO       = 4

# Load PAM
libpam = CDLL(find_library("pam"))

# Define PamHandle as an opaque pointer
class PamHandle(Structure):
    pass

PamHandlePtr = POINTER(PamHandle)

# Set function signatures
pam_start     = libpam.pam_start
pam_start.restype = c_int
pam_start.argtypes = [c_char_p, c_char_p, POINTER(c_void_p), POINTER(PamHandlePtr)]

pam_authenticate = libpam.pam_authenticate
pam_authenticate.restype = c_int
pam_authenticate.argtypes = [PamHandlePtr, c_int]

pam_end = libpam.pam_end
pam_end.restype = c_int
pam_end.argtypes = [PamHandlePtr, c_int]

pam_set_item = libpam.pam_set_item
pam_set_item.restype = c_int
pam_set_item.argtypes = [PamHandlePtr, c_int, c_char_p]

# Conversation function type
CONV_FUNC = CFUNCTYPE(c_int, c_int, POINTER(POINTER(PamMessage)), POINTER(POINTER(PamResponse)), c_void_p)

def authenticate(username, password, service='login'):
    def my_conv(n_messages, messages, p_response, app_data):
        """
        Simple conversation function that responds to any prompt where the echo is off with the supplied password
        """
        # Allocate response array
        resp = (POINTER(PamResponse) * n_messages)()
        for i in range(n_messages):
            msg = messages[i][0]
            if msg.msg_style == PAM_PROMPT_ECHO_OFF:
                # Allocate and copy password
                response = PamResponse()
                response.resp = password.encode('utf-8') if isinstance(password, str) else password
                response.resp_retcode = 0
                resp[i] = pointer(response)
            else:
                # For other messages, leave resp[i] = NULL (PAM will ignore)
                resp[i] = None
        # Write the response pointer
        p_response[0] = resp
        return 0

    conv = CONV_FUNC(my_conv)
    handle = PamHandlePtr()
    
    # Start PAM session
    ret = pam_start(service.encode('utf-8'), username.encode('utf-8'), conv, handle)
    if ret != 0:
        return False

    # Authenticate
    ret = pam_authenticate(handle, 0)
    
    # End session
    pam_end(handle, 0)

    return ret == 0
