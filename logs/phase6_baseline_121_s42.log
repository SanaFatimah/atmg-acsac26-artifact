import re


def checkNumber(number):
    '''
    Use regular expression to match lines with numbers
    '''
    if number is None:
        return False
    
    # Handle both string (multi-line) and list/tuple of strings
    if isinstance(number, str):
        lines = number.splitlines()
    elif isinstance(number, (list, tuple)):
        lines = number
    else:
        return False
    
    # Ensure all lines are strings (CWE-20: avoid non-string types in regex)
    for line in lines:
        if not isinstance(line, str):
            return False
    
    # Use a simple, safe regex to detect digits in any line
    pattern = re.compile(r'\d')
    for line in lines:
        if pattern.search(line):
            return True
    return False
