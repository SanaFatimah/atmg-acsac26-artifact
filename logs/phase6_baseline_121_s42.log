import socket
import ipaddress
import re
import requests
from urllib.parse import urlparse
from flask import Flask, request

app = Flask(__name__)

# Predefined unsafe IP ranges (RFC 1918, loopback, link-local, etc.)
UNSAFE_IP_RANGES = [
    ipaddress.ip_network('127.0.0.0/8'),     # loopback
    ipaddress.ip_network('10.0.0.0/8'),      # private
    ipaddress.ip_network('172.16.0.0/12'),   # private
    ipaddress.ip_network('192.168.0.0/16'),  # private
    ipaddress.ip_network('169.254.0.0/16'),  # link-local
    ipaddress.ip_network('::1/128'),         # IPv6 loopback
    ipaddress.ip_network('fc00::/7'),        # IPv6 unique local
    ipaddress.ip_network('fe80::/10'),       # IPv6 link-local
]

def is_safe_ip(ip_str):
    try:
        ip = ipaddress.ip_address(ip_str)
        for net in UNSAFE_IP_RANGES:
            if ip in net:
                return False
        return True
    except ValueError:
        return False

def resolve_to_ips(domain):
    try:
        return socket.getaddrinfo(domain, None, socket.AF_INET)
    except socket.gaierror:
        return []

def is_safe_domain(domain):
    # Basic validation: only allow alphanumeric, hyphens, and dots; no IP literals
    if not domain or len(domain) > 255:
        return False
    if re.fullmatch(r'[a-zA-Z0-9-]+(?:\.[a-zA-Z0-9-]+)*', domain) is None:
        return False
    # Reject if it looks like an IP address
    try:
        ipaddress.ip_address(domain)
        return False
    except ValueError:
        pass
    return True

@app.route("/full_ssrf")
def full_ssrf():
    subdomain = request.args.get('subdomain', '')
    
    # Validate subdomain format
    if not is_safe_domain(subdomain):
        return "Invalid subdomain", 400

    full_url = f"http://{subdomain}"

    try:
        # Parse and validate URL
        parsed = urlparse(full_url)
        hostname = parsed.netloc

        # Resolve hostname to IP and check each
        addr_info = resolve_to_ips(hostname)
        if not addr_info:
            return "Cannot resolve hostname", 400

        for info in addr_info:
            ip = info[4][0]
            if not is_safe_ip(ip):
                return "Access to this host is forbidden", 403

        # Proceed with safe request
        response = requests.get(full_url, timeout=5)
        return response.text, response.status_code

    except requests.exceptions.RequestException:
        return "Request failed", 500
