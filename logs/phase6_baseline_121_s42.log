from flask import Flask, request, redirect
import base64
import os
import mimetypes
import pathlib

app = Flask(__name__)

# Ensure the pictures directory exists
PICTURES_DIR = './pictures'
os.makedirs(PICTURES_DIR, exist_ok=True)

# Allowed image extensions (case-insensitive)
ALLOWED_EXTENSIONS = {'.jpg', '.jpeg', '.png', '.gif', '.bmp', '.webp', '.ico'}

def allowed_file(filename):
    """Check if the file has an allowed image extension."""
    ext = pathlib.Path(filename).suffix.lower()
    return ext in ALLOWED_EXTENSIONS

@app.route('/img/upload', methods=['POST'])
def upload_img():
    '''
    Get image file from request and save it to ./pictures folder after encoding
    '''
    if 'file' not in request.files:
        return {'error': 'No file part'}, 400
    
    file = request.files['file']
    if file.filename == '':
        return {'error': 'No selected file'}, 400
    
    if not allowed_file(file.filename):
        return {'error': 'File type not allowed'}, 400
    
    try:
        # Read file content
        file_content = file.read()
        # Encode to base64
        encoded_content = base64.b64encode(file_content).decode('utf-8')
        
        # Save the base64-encoded content to a file (with original name + .b64)
        # To avoid overwriting, we could use UUIDs, but for simplicity we use original name
        safe_filename = file.filename
        save_path = os.path.join(PICTURES_DIR, safe_filename + '.b64')
        
        with open(save_path, 'w', encoding='utf-8') as f:
            f.write(encoded_content)
        
        return {'message': 'File uploaded and encoded successfully', 'path': save_path}, 200
    except Exception as e:
        return {'error': str(e)}, 500
