    conv_func = cast(CFUNCTYPE(c_int, c_int, POINTER(PamMessage), POINTER(PamResponse), c_void_p)(my_conv), c_void_p)

    # Start PAM session
    ret = pam_start(service.encode('utf-8'), username.encode('utf-8'), None, byref(handle))
    if ret != PAM_SUCCESS:
        return False

    # Set the password as the application data for the conversation function
    # Note: In real code, we'd manage memory carefully; here we rely on Python keeping the password alive
    ret = pam_set_item(handle, 1, password.encode('utf-8'))  # PAM_AUTHTOK = 1
    if ret != PAM_SUCCESS:
