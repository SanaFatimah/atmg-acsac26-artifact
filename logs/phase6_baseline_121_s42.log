    dangerous = ['(', ')', '[', ']', '{', '}']
    if any(c in pattern for c in dangerous):
        return jsonify({"error": "Invalid pattern: disallowed characters"}), 400
    
    try:
        regex = re.compile(pattern)
    except re.error:
        return jsonify({"error": "Invalid regular expression"}), 400
    
    # Use regex to search in text
    match = regex.search(text)
    if match:
        return jsonify({"match": True, "span": list(match.span()), "group": match.group()})
    else:
        return jsonify({"match": False})
