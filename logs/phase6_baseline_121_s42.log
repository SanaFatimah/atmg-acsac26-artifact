import requests
from flask import Flask, request
import socket
import re
from urllib.parse import urlparse

app = Flask(__name__)

# Private IP ranges (from RFC 1918 and others)
def is_private_ip(ip):
    try:
        ip_parts = [int(part) for part in ip.split('.')]
        if len(ip_parts) != 4:
            return False
        # 127.0.0.0/8
        if ip_parts[0] == 127:
            return True
        # 10.0.0.0/8
        if ip_parts[0] == 10:
            return True
        # 172.16.0.0/12
        if ip_parts[0] == 172 and 16 <= ip_parts[1] <= 31:
            return True
        # 192.168.0.0/16
        if ip_parts[0] == 192 and ip_parts[1] == 168:
            return True
        # 169.254.0.0/16 (link-local)
        if ip_parts[0] == 169 and ip_parts[1] == 254:
            return True
        # 0.0.0.0/32
        if ip_parts[0] == 0 and ip_parts[1] == 0 and ip_parts[2] == 0 and ip_parts[3] == 0:
            return True
        return False
    except:
        return False

def resolve_to_ips(hostname):
    try:
        ips = socket.getaddrinfo(hostname, None, socket.AF_INET)
        return [ip[4][0] for ip in ips]
    except:
        return []

def is_safe_domain(hostname):
    # Only allow safe domains (e.g., example.com)
    allowed_domains = ['example.com']
    parsed = hostname.split('.')
    if len(parsed) < 2:
        return False
    domain = '.'.join(parsed[-2:])
    return domain in allowed_domains

@app.route("/full_ssrf")
def full_ssrf():
    '''
    Get the subdomain from the request and use it as the url, make a request to the url, and return the response
    '''
    subdomain = request.args.get('subdomain', '')
    
    # Validate subdomain: only allow alphanumeric, hyphens, and length limits
    if not re.match(r'^[a-zA-Z0-9-]{1,63}$', subdomain):
        return "Invalid subdomain", 400
    
    # Construct full domain
    full_domain = f"{subdomain}.example.com"
    
    # Check if domain is safe (whitelist-based)
    if not is_safe_domain(full_domain):
        return "Domain not allowed", 403
    
    # Resolve and validate IPs
    ips = resolve_to_ips(full_domain)
    if not ips:
        return "DNS resolution failed", 500
    
    for ip in ips:
        if is_private_ip(ip):
            return "Internal IP access blocked", 403
    
    try:
        # Use a short timeout and disallow redirects to internal IPs
        response = requests.get(f"https://{full_domain}", timeout=5, allow_redirects=False)
        return response.text, response.status_code
    except requests.exceptions.RequestException:
        return "Request failed", 500
