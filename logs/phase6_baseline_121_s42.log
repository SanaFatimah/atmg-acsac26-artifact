from flask import Flask, request
import xml.etree.ElementTree as ET

app = Flask(__name__)


@app.post("/upload")
def upload():
    '''
    Reads the XML from the incoming request.
    Parse it and return.
    '''
    try:
        xml_data = request.data
        if not xml_data:
            return "No XML data provided", 400
        
        # Parse XML safely using the standard library (no external entity resolution by default)
        root = ET.fromstring(xml_data)
        
        # For demonstration, return the tag of the root element
        return f"Root element: {root.tag}", 200
    
    except ET.ParseError as e:
        return f"XML parse error: {str(e)}", 400
    except Exception as e:
        return f"Internal server error: {str(e)}", 500
