import os
from flask import Response, request, Flask

app = Flask(__name__)

@app.route('/reply')
def listFiles():
    username = request.args.get('username', '')
    # Validate username: only allow alphanumeric characters to prevent path traversal
    if not username.isalnum():
        return Response("Invalid username.", status=400)
    
    base_dir = "/home"
    target_dir = os.path.join(base_dir, username)
    
    # Ensure the resolved path is under /home (prevent traversal like ../../etc)
    try:
        real_target = os.path.realpath(target_dir)
        if not real_target.startswith(os.path.realpath(base_dir) + os.sep) and real_target != os.path.realpath(base_dir):
            return Response("Access denied.", status=403)
    except Exception:
        return Response("Invalid path.", status=400)
    
    if not os.path.isdir(real_target):
        return Response("User directory not found.", status=404)
    
    try:
        files = os.listdir(real_target)
        return Response("\n".join(files), mimetype='text/plain')
    except Exception:
        return Response("Permission denied or error reading directory.", status=403)
