import requests
from flask import Flask, request
import socket
import threading
import ipaddress
from urllib.parse import urlparse

app = Flask(__name__)

# SSRF protection: block private IPs
def is_private_ip(ip):
    try:
        return ipaddress.ip_address(ip).is_private
    except ValueError:
        return True  # treat invalid IPs as private (block them)

def get_ip_from_url(url):
    try:
        domain = urlparse(url).hostname
        return socket.gethostbyname(domain)
    except Exception:
        return None

@app.route("/full_ssrf")
def full_ssrf():
    # Get subdomain from query parameter
    subdomain = request.args.get('subdomain', '')
    
    # Validate subdomain: only allow alphanumeric and hyphens, length < 50
    if not subdomain or not re.match(r'^[a-zA-Z0-9-]+$', subdomain) or len(subdomain) > 50:
        return "Invalid subdomain", 400
    
    # Only allow specific subdomains to prevent SSRF
    # Map safe subdomains to known URLs
    safe_subdomains = {
        'api': 'https://api.example.com',
        'cdn': 'https://cdn.example.com'
    }
    
    if subdomain not in safe_subdomains:
        return "Subdomain not allowed", 403
    
    url = safe_subdomains[subdomain]
    
    # Additional SSRF protection: check IP is not private
    ip = get_ip_from_url(url)
    if ip and is_private_ip(ip):
        return "Blocked: private IP address", 403
    
    try:
        response = requests.get(url, timeout=5, allow_redirects=False)
        # Return as plain text to prevent XSS (CWE-079)
        return response.content, response.status_code, {'Content-Type': 'text/plain; charset=utf-8'}
    except requests.exceptions.RequestException:
        return "Error fetching URL", 500
