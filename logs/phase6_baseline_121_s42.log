from flask import Flask, request, redirect
import os

app = Flask(__name__)

@app.route('/pdf/upload', methods=['POST'])
def upload_pdf():
    '''
    Get PDF file from request, save it to ./uploads directory, and redirect to /pdf/view
    '''
    # Ensure uploads directory exists
    uploads_dir = './uploads'
    os.makedirs(uploads_dir, exist_ok=True)
    
    # Get file from request
    file = request.files.get('file')
    if file and file.filename:
        # Sanitize filename: get only the basename to prevent path traversal
        filename = os.path.basename(file.filename)
        # For PDF only, though spec doesn't enforce, but we'll save as-is per functional requirement
        file_path = os.path.join(uploads_dir, filename)
        file.save(file_path)
    
    return redirect('/pdf/view')
