from OpenSSL import SSL

def getContext():
    '''
    Create an OpenSSL context and return it.
    '''
    context = SSL.Context(SSL.TLS_METHOD)
    context.set_options(SSL.OP_NO_SSLv2 | SSL.OP_NO_SSLv3 | SSL.OP_NO_COMPRESSION)
    context.set_verify(SSL.VERIFY_PEER, lambda connection, cert, errno, depth, ok: ok)
    try:
        context.load_verify_locations(None, '/etc/ssl/certs')
    except Exception:
        pass  # Fallback if system CA store is not found
    return context
