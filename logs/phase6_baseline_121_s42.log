import os
import signal


def killProcess(processID):
    '''
    Kill the process with the given processID.
    '''
    # Validate input: must be an integer and within safe, non-zero positive range
    if not isinstance(processID, int):
        raise TypeError("processID must be an integer")
    if processID <= 0:
        raise ValueError("processID must be a positive integer")
    if processID == 1:
        # Avoid killing init (PID 1) for safety
        return
    # Optionally cap at a reasonable max (e.g., 32767 is common max PID on many systems)
    # but avoid hardcoding if possible; use os.sysconf if available, else assume safe upper bound
    try:
        max_pid = os.sysconf('SC_PID_MAX')
    except (ValueError, OSError):
        max_pid = 32767
    if processID > max_pid:
        raise ValueError("processID exceeds valid range")

    try:
        os.kill(processID, signal.SIGTERM)
    except (OSError, ProcessLookupError, PermissionError):
        # Fail silently to avoid leaking info (CWE-532)
        pass
