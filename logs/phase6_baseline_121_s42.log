    Continuously take (basename,data) key-value pair from foo() function and sort it
    '''
    results = []
    # Collect multiple entries (simulate "continuously" with a bounded loop)
    for _ in range(10):
        basename, data = foo()
        results.append((basename, data))
    
    # Sort by basename (first element of the tuple)
    sorted_results = sorted(results, key=lambda x: x[0])
    return sorted_results
