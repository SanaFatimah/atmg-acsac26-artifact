import json
import urllib.request as request
import urllib.parse as parse
import socket
import threading

# Prevent SSRF by blocking private IP ranges (best practice, even if not in do_not_regress)
def _is_safe_url(url):
    try:
        parsed = parse.urlparse(url)
        if parsed.scheme not in ('http', 'https'):
            return False
        hostname = parsed.hostname
        if not hostname:
            return False
        # Resolve hostname to IPs and check if any is private
        # Use getaddrinfo to handle both IPv4 and IPv6
        try:
            addr_info = socket.getaddrinfo(hostname, None, socket.AF_UNSPEC, socket.SOCK_STREAM)
            for family, socktype, proto, canonname, sockaddr in addr_info:
                ip = sockaddr[0]
                # Private IP ranges
                if ip == '127.0.0.1' or ip == '::1':
                    return False
                # IPv4 private ranges
                if ip.startswith('10.') or ip.startswith('172.') or ip.startswith('192.168.'):
                    # More precise check for 172.16.0.0 - 172.31.255.255
                    if ip.startswith('172.'):
                        parts = ip.split('.')
                        if len(parts) >= 2:
                            second_octet = int(parts[1])
                            if 16 <= second_octet <= 31:
                                return False
                    else:
                        return False
                # Link-local and other reserved
                if ip.startswith('169.254.') or ip.startswith('0.0.0.0'):
                    return False
        except socket.gaierror:
            # Cannot resolve hostname, treat as unsafe
            return False
        return True
    except Exception:
        return False

def readJSON(url):
    '''
    Read a json file from a url
    and return the parsed json object
    '''
    # Validate URL to prevent path traversal and SSRF
    if not _is_safe_url(url):
        raise ValueError("Invalid or unsafe URL")
    
    with request.urlopen(url, timeout=10) as response:
        data = response.read()
        return json.loads(data.decode('utf-8'))
