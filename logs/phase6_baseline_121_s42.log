from django.http import HttpResponseRedirect
from django.utils.http import is_safe_url
from urllib.parse import urlparse

def http_responser_redirect(request):
    '''
    Get the target url from the request and redirect to it
    '''
    redirect_to = request.GET.get('next', request.POST.get('next', ''))
    if redirect_to:
        # Validate the URL to prevent open redirect vulnerabilities (CWE-601)
        # Check if it's a relative URL (starts with '/') and not a full URL
        parsed = urlparse(redirect_to)
        if not parsed.scheme and not parsed.netloc and is_safe_url(redirect_to, allowed_hosts={request.get_host()}):
            return HttpResponseRedirect(redirect_to)
    # Fallback to home or safe default
    return HttpResponseRedirect('/')
