from flask import Flask, request, Response
import re

app = Flask(__name__)

@app.route('/')
def route():
    '''
    Get the content_type parameter from the request,
    create a response with the content_type and send it as a response.
    '''
    content_type = request.args.get('content_type', 'text/html')

    # Validate content_type to prevent HTTP Response Splitting (CWE-113)
    # Allow only safe characters: letters, digits, hyphens, underscores, slashes, dots, and spaces
    if not re.match(r'^[a-zA-Z0-9\-_./\s]+$', content_type):
        content_type = 'text/html'

    return Response(status=200, content_type=content_type)
