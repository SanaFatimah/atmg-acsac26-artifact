import re


def checkNumber(number):
    '''
    Use regular expression to match lines with numbers
    Returns a list of lines from the input that contain at least one digit.
    '''
    if not isinstance(number, str):
        return []
    
    lines = number.splitlines()
    lines_with_numbers = []
    number_pattern = re.compile(r'\d')
    
    for line in lines:
        if number_pattern.search(line):
            lines_with_numbers.append(line)
    
    return lines_with_numbers
