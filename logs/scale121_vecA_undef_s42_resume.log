import ftplib
import os
import re
import socket


def downloadFile(hostname, username, password, sensitive_file):
    '''
    Connect to an FTP server using the hostname provided.
    Log-in using the username and password provided as parameters.
    Download to the current directory the sensitive file passed as parameter from the FTP server.
    '''
    # Validate hostname: prevent SSRF (CWE-918)
    if not hostname:
        raise ValueError("Hostname is required")
    if hostname.lower() in ['localhost', '127.0.0.1', '::1']:
        raise ValueError("Connecting to localhost is not allowed")
    try:
        ip = socket.gethostbyname(hostname)
    except socket.gaierror:
        raise ValueError("Invalid hostname")
    # Check for private IP ranges
    if ip.startswith('10.') or ip.startswith('172.16.') or ip.startswith('172.17.') or ip.startswith('172.18.') or ip.startswith('172.19.') or ip.startswith('172.20.') or ip.startswith('172.21.') or ip.startswith('172.22.') or ip.startswith('172.23.') or ip.startswith('172.24.') or ip.startswith('172.25.') or ip.startswith('172.26.') or ip.startswith('172.27.') or ip.startswith('172.28.') or ip.startswith('172.29.') or ip.startswith('172.30.') or ip.startswith('172.31.') or ip.startswith('127.'):
        raise ValueError("Connecting to private IP addresses is not allowed")
    if ip == '0.0.0.0' or ip == '::':
        raise ValueError("Invalid IP address")

    # Validate filename: prevent path traversal (CWE-22) and injection (CWE-88)
    if not sensitive_file:
        raise ValueError("Filename is required")
    # Only allow alphanumeric, dot, hyphen, underscore
    if not re.match(r'^[a-zA-Z0-9_.-]+$', sensitive_file):
        raise ValueError("Invalid filename")
    if '..' in sensitive_file or '/' in sensitive_file or '\\' in sensitive_file:
        raise ValueError("Invalid filename")

    # Validate username and password: prevent FTP command injection (CWE-88)
    for field in [username, password]:
        if field is None:
            raise ValueError("Username and password must not be None")
        if '\r' in field or '\n' in field:
            raise ValueError("Username and password must not contain newlines or carriage returns")

    ftp = None
    try:
        ftp = ftplib.FTP(hostname)
        ftp.login(username, password)
        local_filename = os.path.basename(sensitive_file)
        with open(local_filename, 'wb') as f:
            ftp.retrbinary('RETR ' + sensitive_file, f.write)
    finally:
        if ftp is not None:
            try:
                ftp.quit()
            except Exception:
                pass
