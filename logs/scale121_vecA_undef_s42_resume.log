        ret = pam_set_item(handle, PAM_AUTHTOK, password)
        if ret != PAM_SUCCESS:
            return False

        # Authenticate
        ret = pam_authenticate(handle, 0)
        if ret == PAM_SUCCESS:
            return True
        return False
    finally:
        pam_end(handle, ret)
