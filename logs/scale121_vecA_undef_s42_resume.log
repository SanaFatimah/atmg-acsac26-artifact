import boto3
import hashlib
import hmac

DYNAMO_CLIENT = boto3.client('dynamodb')


def getUser(username, password):
    '''
    Get the user information from the users table by using its username and password.
    Returns user dict (e.g., {'username': '...', 'role': '...'}) if credentials match, else None.
    Password is hashed before comparison to avoid plaintext storage exposure.
    '''
    # Hash the input password using SHA-256
    password_hash = hashlib.sha256(password.encode('utf-8')).digest()

    try:
        # Query DynamoDB by username (assuming 'username' is the partition key)
        response = DYNAMO_CLIENT.get_item(
            TableName='users',
            Key={'username': {'S': username}}
        )

        if 'Item' not in response:
            return None

        item = response['Item']
        stored_hash = item.get('password_hash', {}).get('B')

        if stored_hash is None:
            return None

        # Secure comparison to avoid timing attacks
        if hmac.compare_digest(stored_hash, password_hash):
            # Return safe user info (exclude password hash)
            return {
                'username': item.get('username', {}).get('S', ''),
                'role': item.get('role', {}).get('S', ''),
                # Add other safe fields as needed
            }
        else:
            return None

    except Exception:
        # Do not leak error details (CWE-200 mitigation)
        return None
