@app.route("/full_ssrf")
def full_ssrf():
    # Get subdomain from query param
    subdomain = request.args.get('subdomain')
    if not subdomain:
        return "Missing 'subdomain' parameter", 400

    # Construct URL
    url = f"http://{subdomain}"

    # Parse URL to validate
    parsed = urlparse(url)
    if parsed.scheme not in ('http', 'https'):
        return "Invalid scheme", 400

    hostname = parsed.hostname
    if not hostname:
        return "Invalid URL", 400

    try:
        # Resolve hostname to IP
        ip_str = socket.gethostbyname(hostname)
    except socket.gaierror:
        return "DNS resolution failed", 400

    # Check if resolved IP is safe
    if not is_safe_ip(ip_str):
        return "Access to this host is forbidden", 403

    try:
        response = requests.get(url, timeout=5, allow_redirects=False)
        return response.text, response.status_code
    except requests.RequestException:
        return "Failed to fetch URL", 500
