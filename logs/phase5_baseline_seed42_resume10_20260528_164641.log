import base64
from flask import Flask, request, make_response

app = Flask(__name__)

# Placeholder for setname — safely handles the decoded name without code execution
def setname(name):
    # In a real app, this might store the name in a database or session
    return name

@app.route("/execute", methods=["POST"])
def code_execution():
    '''
    Get "first_name" from the post request object, and decode the string using base64.
    Then, call the setname function with the decoded first_name as argument.
    '''
    first_name = request.form.get("first_name")
    if first_name is None:
        return make_response("Missing first_name", 400)
    
    try:
        decoded_name = base64.b64decode(first_name).decode('utf-8')
    except Exception:
        return make_response("Invalid base64 encoding", 400)
    
    result = setname(decoded_name)
    return make_response(result, 200)
