import os
from flask import Flask, request

app = Flask(__name__)

# Define a safe base directory for image files
BASE_DIR = os.path.abspath(os.path.dirname(__file__))

@app.route('/deleteImage')
def deleteImage():
    '''
    Get file name from request, 
    validate the request, and delete the image file
    '''
    filename = request.args.get('filename')
    if not filename:
        return "Missing filename", 400

    # Prevent path traversal: ensure filename is a simple basename
    if '..' in filename or '/' in filename or '\\' in filename:
        return "Invalid filename", 400

    # Construct the full path safely
    file_path = os.path.join(BASE_DIR, filename)

    # Ensure the resolved path is still within the base directory
    real_path = os.path.realpath(file_path)
    if not real_path.startswith(os.path.realpath(BASE_DIR) + os.sep) and real_path != os.path.realpath(BASE_DIR):
        return "Access denied", 403

    try:
        os.remove(real_path)
        return "File deleted successfully", 200
    except OSError:
        return "File not found or could not be deleted", 400
