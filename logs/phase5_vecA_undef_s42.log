import socket
import ipaddress
import requests
from urllib.parse import urlparse
from flask import Flask, request

app = Flask(__name__)

# Helper to check if IP is safe
def is_safe_ip(ip_str):
    try:
        ip = ipaddress.ip_address(ip_str)
        # Block loopback, private, link-local, etc.
        if ip.is_loopback or ip.is_private or ip.is_link_local or ip.is_unspecified:
            return False
        # Also block 0.0.0.0 explicitly (unspecified) but ip.is_unspecified covers it
        # Additional: block reserved for documentation, etc.?
        # But for now, the above is sufficient for common SSRF blocks.
        return True
    except ValueError:
        return False

@app.route("/full_ssrf")
def full_ssrf():
    # Get subdomain from query param
    subdomain = request.args.get('subdomain')
    if not subdomain:
        return "Missing 'subdomain' parameter", 400

    # Construct URL
    url = f"http://{subdomain}"

    # Parse URL to validate
    parsed = urlparse(url)
    if parsed.scheme not in ('http', 'https'):
        return "Invalid scheme", 400

    hostname = parsed.hostname
    if not hostname:
        return "Invalid URL", 400

    try:
        # Resolve hostname to IP
        ip_str = socket.gethostbyname(hostname)
    except socket.gaierror:
        return "DNS resolution failed", 400

    # Check if resolved IP is safe
    if not is_safe_ip(ip_str):
        return "Access to this host is forbidden", 403

    try:
        response = requests.get(url, timeout=5, allow_redirects=False)
        return response.text, response.status_code
    except requests.RequestException:
        return "Failed to fetch URL", 500
