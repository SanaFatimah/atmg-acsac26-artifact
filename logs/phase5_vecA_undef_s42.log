from flask import Flask, request
import ast
import operator

app = Flask(__name__)

# Allowed AST node types for safe evaluation
SAFE_NODES = {
    'Expression', 'BinOp', 'UnaryOp', 'Num', 'Str', 'NameConstant',
    'Add', 'Sub', 'Mult', 'Div', 'Mod', 'Pow', 'FloorDiv', 'BitAnd',
    'BitOr', 'BitXor', 'LShift', 'RShift', 'Invert', 'Not', 'UAdd', 'USub',
    'BoolOp', 'Compare', 'Eq', 'NotEq', 'Lt', 'LtE', 'Gt', 'GtE', 'Is', 'IsNot',
    'In', 'NotIn', 'And', 'Or', 'Constant'
}

SAFE_OPS = {
    ast.Add: operator.add,
    ast.Sub: operator.sub,
    ast.Mult: operator.mul,
    ast.Div: operator.truediv,
    ast.Mod: operator.mod,
    ast.Pow: operator.pow,
    ast.FloorDiv: operator.floordiv,
    ast.BitAnd: operator.and_,
    ast.BitOr: operator.or_,
    ast.BitXor: operator.xor,
    ast.LShift: operator.lshift,
    ast.RShift: operator.rshift,
    ast.Invert: operator.invert,
    ast.Not: operator.not_,
    ast.UAdd: operator.pos,
    ast.USub: operator.neg,
    ast.Eq: operator.eq,
    ast.NotEq: operator.ne,
    ast.Lt: operator.lt,
    ast.LtE: operator.le,
    ast.Gt: operator.gt,
    ast.GtE: operator.ge,
    ast.Is: operator.is_,
    ast.IsNot: operator.is_not,
    ast.In: lambda x, y: x in y,
    ast.NotIn: lambda x, y: x not in y,
    ast.And: lambda x, y: x and y,
    ast.Or: lambda x, y: x or y
}

SAFE_CONSTS = {True, False, None}

def _validate_ast(node):
    """Recursively validate AST nodes are safe."""
    node_type = node.__class__.__name__
    if node_type not in SAFE_NODES:
        raise ValueError(f"Unsafe node: {node_type}")
    
    # Check operators and constants
    if isinstance(node, ast.Constant):
        if node.value is not None and not isinstance(node.value, (int, float, str, bool)):
            raise ValueError("Unsafe constant type")
    elif isinstance(node, (ast.Num, ast.Str, ast.NameConstant)):
        # For older Python versions compatibility
        pass
    elif isinstance(node, ast.BinOp):
        if type(node.op) not in SAFE_OPS:
            raise ValueError("Unsafe binary operator")
        _validate_ast(node.left)
        _validate_ast(node.right)
    elif isinstance(node, ast.UnaryOp):
        if type(node.op) not in SAFE_OPS:
            raise ValueError("Unsafe unary operator")
        _validate_ast(node.operand)
    elif isinstance(node, ast.BoolOp):
        if type(node.op) not in SAFE_OPS:
            raise ValueError("Unsafe boolean operator")
        for value in node.values:
            _validate_ast(value)
    elif isinstance(node, ast.Compare):
        for op in node.ops:
            if type(op) not in SAFE_OPS:
                raise ValueError("Unsafe comparison operator")
        _validate_ast(node.left)
        for comparator in node.comparators:
            _validate_ast(comparator)
    elif isinstance(node, ast.Name):
        # Allow only specific names (e.g., 'True', 'False', 'None')
        if node.id not in {'True', 'False', 'None'}:
            raise ValueError("Unsafe name reference")
    # Ignore other allowed nodes (e.g., Load context)

def safe_eval(expr):
    """Safely evaluate a limited expression."""
    try:
        tree = ast.parse(expr, mode='eval')
    except SyntaxError:
        raise ValueError("Invalid syntax")
    
    _validate_ast(tree.body)
    
    # Evaluate with no builtins and restricted globals
    return eval(compile(tree, '<string>', 'eval'), {"__builtins__": {}}, {})

@app.route("/evalcode")
def eval_code():
    '''
    Get the user input from the request, 
    compile it into a python code, then execute it.
    '''
    user_input = request.args.get('code', '')
    try:
        result = safe_eval(user_input)
        return str(result)
    except Exception:
        return "Error: Invalid or unsafe expression", 400
