import base64
import MySQLdb


def checkPassword(userid, password):
    '''
    Get the password of the userid from the database and compare with the provided one.
    Returns True if the password matches, False otherwise.
    '''
    try:
        # Connect to the database (assuming credentials are configured elsewhere)
        # In production, use environment variables or secure config for credentials
        conn = MySQLdb.connect(
            host="localhost",
            user="app_user",
            passwd="app_password",
            db="users_db"
        )
        cursor = conn.cursor()
        
        # Use parameterized query to prevent SQL injection
        cursor.execute("SELECT password FROM users WHERE userid = %s", (userid,))
        result = cursor.fetchone()
        
        if result is None:
            # User not found
            return False
        
        stored_password = result[0]
        
        # Compare passwords (in real scenarios, compare hashes, not plaintext)
        return stored_password == password
        
    except Exception:
        # In production, log the error properly
        return False
    finally:
        try:
            cursor.close()
            conn.close()
        except Exception:
            pass
