import re


def filterScriptTags(content):
    '''
    Remove <script> tags and their content from the content argument.
    '''
    # Remove <script>...</script> blocks (case-insensitive, including attributes and multiline)
    return re.sub(r'<script[^>]*>.*?</script>', '', content, flags=re.IGNORECASE | re.DOTALL)
