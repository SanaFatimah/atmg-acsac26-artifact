import subprocess

def executeCommand():
    '''
    Read a command from a user input, validate it, and execute it
    '''
    # Define allowed commands (simple whitelist)
    allowed_commands = {"ls", "echo", "pwd"}
    
    # Read command from user input
    user_input = input("Enter a command: ").strip()
    
    # Basic validation: check against whitelist and ensure no shell metacharacters
    if not user_input:
        print("No command provided.")
        return
    
    # Split input into command and arguments
    parts = user_input.split()
    cmd = parts[0]
    
    # Check if command is in whitelist
    if cmd not in allowed_commands:
        print("Command not allowed.")
        return
    
    # Additional check: ensure no shell metacharacters in any part
    dangerous_chars = {';', '|', '&', '$', '`', '>', '<', '*', '?', '{', '}', '(', ')', '[', ']', '~', '!', '#'}
    for part in parts:
        for char in dangerous_chars:
            if char in part:
                print("Invalid characters in command.")
                return
    
    # Execute safely with shell=False
    try:
        subprocess.run([cmd] + parts[1:], check=True)
    except subprocess.CalledProcessError as e:
        print(f"Command failed with exit code {e.returncode}")
    except Exception as e:
        print(f"Error executing command: {e}")
