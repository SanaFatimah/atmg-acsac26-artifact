import os


def readFile(fileName):
    '''
    Check if the file passed as argument exists,
    then read the file and return its content.
    '''
    # Resolve to absolute path to prevent path traversal
    abs_path = os.path.abspath(fileName)
    # Ensure the path is within the current working directory (or its subdirectories)
    cwd = os.path.abspath(os.getcwd())
    if not abs_path.startswith(cwd + os.sep) and abs_path != cwd:
        return None
    # Check if file exists and is a regular file
    if os.path.isfile(abs_path):
        with open(abs_path, 'r') as f:
            return f.read()
    return None
