import os
import re


def invalidUsername(username):
    """
    Returns True if username is invalid, False otherwise.
    A valid username:
    - is non-empty
    - contains only alphanumeric characters, underscores, and hyphens
    - does not contain path traversal elements like '..' or absolute path components
    """
    if not isinstance(username, str) or not username:
        return True
    # Disallow path separators and traversal attempts
    if '/' in username or '\\' in username or '..' in username:
        return True
    # Allow only alphanumeric, underscore, and hyphen
    if not re.match(r'^[a-zA-Z0-9_-]+$', username):
        return True
    return False


def raisePrivileges():
    """
    Temporarily raises the program's privileges.
    In a real system, this might call os.setuid(0) or similar.
    For this example, it's a no-op since actual privilege changes require admin rights.
    """
    pass


def lowerPrivileges():
    """
    Lowers the program's privileges back to normal.
    In a real system, this might restore the original UID.
    For this example, it's a no-op.
    """
    pass


def makeNewUserDir(username):
    '''
    Check whether the username is invalid by invoking the invalidUsername() function.
    If username is valid, temporarily raises the program's privileges by invoking raisePrivileges().
    Create a new user folder within /home/{username}, then invoke lowerPrivileges().
    Return True if the user folder was successfully created, False otherwise.
    '''
    if invalidUsername(username):
        return False

    user_dir = f"/home/{username}"
    try:
        raisePrivileges()
        os.makedirs(user_dir, exist_ok=True)
        return True
    except (OSError, IOError):
        return False
    finally:
        lowerPrivileges()
